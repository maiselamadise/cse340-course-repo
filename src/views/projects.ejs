<%- include('partials/header') %>

<main>
    <h1>Upcoming Projects</h1>

    <p><a href="/new-project">Add a New Service Project</a></p>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <h2>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>
                </h2>

                <p><%= project.description %></p>

                <p>
                    Organization:
                    <a href="/organization/<%= project.organization_id %>">
                        <%= project.organization_name %>
                    </a>
                </p>

                <p>
                    Start Date:
                    <%= project.start_date %>
                </p>

                <p class="actions">
                    <a href="/edit-project/<%= project.project_id %>">Edit</a> |
                    <a href="/project/<%= project.project_id %>">View Details</a>
                </p>
            </li>
        <% }) %>
    </ul>
</main>

<%- include('partials/footer') %>