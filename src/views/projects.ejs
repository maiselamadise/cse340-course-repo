<%- include('partials/header') %>

<h1>Upcoming Projects</h1>

<% if (isAdmin) { %>
    <p><a href="/new-project" class="btn">+ Add New Project</a></p>
<% } %>

<section>
    <% if (projects.length === 0) { %>
        <p>No projects found.</p>
    <% } else { %>
        <ul class="card-list">
            <% projects.forEach(project => { %>
                <li class="card">
                    <div class="card-body">
                        <h2>
                            <a href="/project/<%= project.project_id %>">
                                <%= project.title %>
                            </a>
                        </h2>

                        <p><%= project.description %></p>

                        <p>
                            <strong>Organization:</strong>
                            <a href="/organization/<%= project.organization_id %>">
                                <%= project.organization_name %>
                            </a>
                        </p>

                        <p>
                            <strong>Start Date:</strong>
                            <%= new Date(project.start_date).toLocaleDateString('en-ZA', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                        </p>

                        <p class="actions">
                            <a href="/project/<%= project.project_id %>">View Details</a>
                            <% if (isAdmin) { %>
                                | <a href="/edit-project/<%= project.project_id %>">Edit</a>
                                | <a href="/assign-categories/<%= project.project_id %>">Assign Categories</a>
                            <% } %>
                        </p>
                    </div>
                </li>
            <% }) %>
        </ul>
    <% } %>
</section>

<%- include('partials/footer') %>
