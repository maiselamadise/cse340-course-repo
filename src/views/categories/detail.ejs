<!-- src/views/categories/detail.ejs -->

<h1>
  <%= category.category_name %>
</h1>

<h3>Projects</h3>

<% if(projects.length > 0) { %>

  <ul>

    <% projects.forEach(project => { %>

      <li>
        <a
          href="/project/<%= project.project_id %>"
        >
          <%= project.title %>
        </a>
      </li>

    <% }) %>

  </ul>

<% } else { %>

  <p>No projects found.</p>

<% } %>