<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= title %></title>

    <link rel="stylesheet" href="/css/main.css">
</head>

<body>

<header>

    <nav>

        <a href="/">Home</a>

        <a href="/organizations">
            Organizations
        </a>

        <a href="/projects">
            Projects
        </a>

        <a href="/categories">
            Categories
        </a>

        <% if (user) { %>

            <a href="/dashboard">
                Dashboard
            </a>

            <a href="/logout">
                Logout
            </a>

        <% } else { %>

            <a href="/login">
                Login
            </a>

            <a href="/register">
                Register
            </a>

        <% } %>

        <% if (user && user.role === 'admin') { %>

            <a href="/users">
                Users
            </a>

            <a href="/new-project">
                New Project
            </a>

            <a href="/new-organization">
                New Organization
            </a>

            <a href="/new-category">
                New Category
            </a>

        <% } %>

    </nav>

</header>