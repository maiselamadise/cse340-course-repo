<!-- src/views/projects/index.ejs -->

<h1>Projects</h1>

<% if(projects.length > 0) { %>

  <ul>
    <% projects.forEach(project => { %>

      <li>
        <a
          href="/projects/<%= project.project_id %>"
        >
          <%= project.project_name %>
        </a>

        -
        <%= project.organization_name %>
      </li>

    <% }) %>
  </ul>

<% } else { %>

  <p>No projects found.</p>

<% } %>