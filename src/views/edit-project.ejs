
<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

 <form action="/edit-projects/<%= project.project_id %>" method="POST">
    <div class="form-group">
      <label for="title">Project Title</label>
      <input
        type="text"
        id="title"
        name="title"
        value="<%= project.title %>"
        maxlength="150"
        required
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        maxlength="1000"
        required
      ><%= project.description %></textarea>
    </div>

    <div class="form-group">
      <label for="location">Location</label>
      <input
        type="text"
        id="location"
        name="location"
        value="<%= project.location || '' %>"
        maxlength="255"
        required
      />
    </div>

    <div class="form-group">
      <label for="startDate">Start Date</label>
      <input
        type="date"
        id="startDate"
        name="startDate"
        value="<%= project.start_date ? String(project.start_date).slice(0, 10) : '' %>"
        required
      />
    </div>

    <div class="form-group">
      <label for="endDate">End Date</label>
      <input
        type="date"
        id="endDate"
        name="endDate"
        value="<%= project.end_date ? String(project.end_date).slice(0, 10) : '' %>"
      />
    </div>

    <div class="form-group">
      <label for="organizationId">Organization</label>
      <select
        id="organizationId"
        name="organizationId"
        required
      >
        <option value="">Select an organization</option>
        <% organizations.forEach(org => { %>
          <option
            value="<%= org.organization_id %>"
            <%= org.organization_id === project.organization_id ? 'selected' : '' %>
          ><%= org.name %></option>
        <% }); %>
      </select>
    </div>

    <button type="submit">Update Project</button>
  </form>

</main>
<%- include('partials/footer') %>
