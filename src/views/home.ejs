<%- include('partials/header') %>

<section class="hero">
    <h1>Welcome to the Community Projects Directory</h1>
    <p>Discover and support community service projects across South Africa.</p>

    <div class="hero-links">
        <a href="/organizations" class="btn">Browse Organizations</a>
        <a href="/projects" class="btn">View Projects</a>
    </div>
</section>

<section>
    <h2>About This Site</h2>
    <p>
        This directory connects volunteers and donors with local nonprofit
        organizations running community service projects. Browse upcoming projects,
        explore partnering organizations, and find opportunities to make a difference.
    </p>

    <% if (!isLoggedIn) { %>
        <p>
            <a href="/register">Create an account</a> to get started,
            or <a href="/login">log in</a> if you already have one.
        </p>
    <% } else { %>
        <p>
            Welcome back, <strong><%= user.name %></strong>!
            Visit your <a href="/dashboard">dashboard</a> to manage your account.
        </p>
    <% } %>
</section>

<%- include('partials/footer') %>
