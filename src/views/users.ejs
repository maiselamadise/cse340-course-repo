<%- include('partials/header') %>

<h1><%= title %></h1>

<section>
    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
            </tr>
        </thead>
        <tbody>
            <% if (users.length === 0) { %>
                <tr>
                    <td colspan="4">No users found.</td>
                </tr>
            <% } else { %>
                <% users.forEach((u, i) => { %>
                    <tr>
                        <td><%= i + 1 %></td>
                        <td><%= u.name %></td>
                        <td><%= u.email %></td>
                        <td><span class="role-badge role-<%= u.role %>"><%= u.role %></span></td>
                    </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>
</section>

<%- include('partials/footer') %>
