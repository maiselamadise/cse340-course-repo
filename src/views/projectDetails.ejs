<%- include('partials/header') %>

<main>
    <h1><%= project.title %></h1>

    <p><%= project.description %></p>

    <p>
        Organization:
        <a href="/organization/<%= project.organization_id %>">
            <%= project.organization_name %>
        </a>
    </p>

    <p>
        Start Date:
        <%= project.start_date %>
    </p>

    <p>
        End Date:
        <%= project.end_date %>
    </p>

    <% if (isLoggedIn) { %>
        <section class="volunteer-section">

            <% if (isVolunteering) { %>

                <p>You are volunteering for this project.</p>

                <form
                    action="/projects/<%= project.project_id %>/remove-volunteer"
                    method="POST"
                >
                    <button type="submit" class="btn">
                        Remove me as a volunteer
                    </button>
                </form>

            <% } else { %>

                <form
                    action="/projects/<%= project.project_id %>/volunteer"
                    method="POST"
                >
                    <button type="submit" class="btn">
                        Volunteer for this project
                    </button>
                </form>

            <% } %>

        </section>
    <% } %>

    <h2>Categories</h2>

    <p>
        <a href="/edit-projects/<%= project.project_id %>">
            Edit Project
        </a>
    </p>

    <p>
        <a href="/assign-categories/<%= project.project_id %>">
            Edit Categories
        </a>
    </p>

    <% if (categories.length === 0) { %>
        <p>No categories assigned.</p>
    <% } %>

    <div class="category-tags">
        <% categories.forEach(category => { %>

            <a
                class="category-tag"
                href="/category/<%= category.category_id %>"
            >
                <%= category.category_name %>
            </a>

        <% }) %>
    </div>
</main>

<%- include('partials/footer') %>